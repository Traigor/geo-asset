{
  "name": "geo-asset-tracker",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "db:up": "docker compose up -d postgres postgres-test",
    "db:migrate": "npm run db:migrate -w backend",
    "db:seed": "npm run db:seed -w backend",
    "test": "npm test --workspaces",
    "test:backend": "npm test -w backend",
    "test:frontend": "npm test -w frontend",
    "typecheck": "npm run typecheck --workspaces",
    "typecheck:backend": "npm run typecheck -w backend",
    "typecheck:frontend": "npm run typecheck -w frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
